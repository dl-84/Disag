<Window x:Class="Sektionsliga.Views.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Sektionsliga.ViewModels"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:DataType="vm:MainWindowViewModel"
        Height="750"
        Icon="/Assets/Disag/Logo.png"
        MinHeight="600"
        MinWidth="900"
        Title="Sektionsliga"
        Width="1200"
        d:DesignHeight="750"
        d:DesignWidth="1200"
        mc:Ignorable="d">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <ControlTheme x:Key="NavItemTheme"
                      TargetType="ListBoxItem">
            <Setter Property="Padding" Value="28,12,20,12" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0"
                            Padding="28,12,20,12">
                        <TextBlock x:CompileBindings="False"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextOnDarkBrush}"
                                   Text="{Binding Label}" />
                    </Border>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="#1AFFFFFF" />
                <Setter Property="Opacity" Value="0.9" />
            </Style>
            <Style Selector="^:selected">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                <Setter Property="Background" Value="#2E019DC6" />
                <Setter Property="Opacity" Value="1" />
            </Style>
        </ControlTheme>
    </Window.Resources>

    <Grid ColumnDefinitions="220,*">

        <!--  Sidebar  -->
        <Border Grid.Column="0"
                Background="{DynamicResource PrimaryBrush}">
            <StackPanel Margin="0,16,0,0">

                <!--  Competition  -->
                <TextBlock Classes="label"
                           Foreground="{DynamicResource TextOnDarkBrush}"
                           Margin="20,16,20,4"
                           Opacity="0.4"
                           Text="WETTKAMPF" />
                <ListBox Background="Transparent"
                         BorderThickness="0"
                         CornerRadius="0"
                         ItemContainerTheme="{StaticResource NavItemTheme}"
                         ItemsSource="{Binding CompetitionItems}"
                         Padding="0"
                         SelectedItem="{Binding SelectedCompetitionItem}" />

                <!--  Settings  -->
                <TextBlock Classes="label"
                           Foreground="{DynamicResource TextOnDarkBrush}"
                           Margin="20,28,20,4"
                           Opacity="0.4"
                           Text="EINSTELLUNGEN" />
                <ListBox Background="Transparent"
                         BorderThickness="0"
                         CornerRadius="0"
                         ItemContainerTheme="{StaticResource NavItemTheme}"
                         ItemsSource="{Binding SettingsItems}"
                         Padding="0"
                         SelectedItem="{Binding SelectedSettingsItem}" />

                <!--  Info  -->
                <TextBlock Classes="label"
                           Foreground="{DynamicResource TextOnDarkBrush}"
                           Margin="20,28,20,4"
                           Opacity="0.4"
                           Text="INFO" />
                <ListBox Background="Transparent"
                         BorderThickness="0"
                         CornerRadius="0"
                         ItemContainerTheme="{StaticResource NavItemTheme}"
                         ItemsSource="{Binding InfoItems}"
                         Padding="0"
                         SelectedItem="{Binding SelectedInfoItem}" />

            </StackPanel>
        </Border>

        <!--  Content Area  -->
        <ContentControl Grid.Column="1"
                        Background="{DynamicResource AppBackgroundAltBrush}"
                        Content="{Binding CurrentPage}" />

    </Grid>
</Window>
