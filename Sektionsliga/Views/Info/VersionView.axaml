<UserControl x:Class="Sektionsliga.Views.Info.VersionView"
             xmlns="https://github.com/avaloniaui"
             xmlns:loc="using:Sektionsliga.Extensions"
             xmlns:vm="using:Sektionsliga.ViewModels.Info"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:DataType="vm:VersionViewModel">
    <Border Padding="32">
        <TextBlock Classes="h2"
                   Text="{loc:Localization Version}" />
    </Border>
</UserControl>
