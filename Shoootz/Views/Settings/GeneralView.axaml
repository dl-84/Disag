<UserControl x:Class="Shoootz.Views.Settings.GeneralView"
             xmlns="https://github.com/avaloniaui"
             xmlns:loc="using:Shoootz.Extensions"
             xmlns:models="using:Shoootz.Models.Settings.Language"
             xmlns:vm="using:Shoootz.ViewModels.Settings"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:DataType="vm:GeneralViewModel">

    <ScrollViewer>
        <StackPanel Classes="page-content">

            <!--  Language  -->
            <Border Classes="card">
                <StackPanel Spacing="16">

                    <TextBlock Classes="h4"
                               Text="{loc:Localization General}" />

                    <StackPanel Spacing="2">
                        <TextBlock Classes="label"
                                   FontSize="13"
                                   Text="{loc:Localization Language}" />
                        <ComboBox ItemsSource="{Binding LanguageOptions}"
                                  SelectedItem="{Binding SelectedLanguageOption}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:LanguageOptionModel">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <Image Height="24"
                                               Source="{Binding Flag}"
                                               VerticalAlignment="Center"
                                               Width="40" />
                                        <TextBlock Text="{Binding CultureInfo.NativeName}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!--  Settings Buttons  -->
            <Border Classes="card">
                <StackPanel Spacing="16">

                    <TextBlock Classes="h4"
                               Text="{loc:Localization Settings}" />

                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <Button Classes="large green"
                                Command="{Binding OpenSettingsFolderCommand}"
                                Content="{loc:Localization OpenFolder}" />
                        <Button Classes="large green"
                                Command="{Binding ShowSettingsContentCommand}"
                                Content="{loc:Localization ShowSettings}" />
                    </StackPanel>

                </StackPanel>
            </Border>

            <!--  Danger Zone  -->
            <Border Classes="card">
                <StackPanel Spacing="16">

                    <TextBlock Classes="h4"
                               Foreground="{DynamicResource ErrorBrush}"
                               Text="{loc:Localization DangerZone}" />

                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <Button Classes="danger large"
                                Command="{Binding DeleteSettingsFolderCommand}"
                                Content="{loc:Localization DeleteAll}" />
                        <Button Classes="danger large"
                                Command="{Binding DeleteSettingsFileCommand}"
                                Content="{loc:Localization DeleteSettingsFile}" />
                    </StackPanel>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
