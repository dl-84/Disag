<Window x:Class="Shoootz.Views.Dialogs.SettingsContentDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:avaloniaEdit="using:AvaloniaEdit"
        xmlns:loc="using:Shoootz.Extensions"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="Transparent"
        CanResize="False"
        Height="650"
        TransparencyLevelHint="Transparent"
        Width="800"
        WindowDecorations="None"
        WindowStartupLocation="CenterOwner">

    <Border ClipToBounds="True"
            CornerRadius="10">
        <Grid Background="{DynamicResource AppBackgroundAltBrush}"
              RowDefinitions="Auto,*,Auto">

            <Border Grid.Row="0"
                    Background="{DynamicResource PrimaryBrush}"
                    Padding="24,12">
                <TextBlock Classes="label"
                           FontSize="16"
                           Foreground="{DynamicResource PrimaryForegroundBrush}"
                           Text="{loc:Localization ShowSettings}" />
            </Border>

            <avaloniaEdit:TextEditor x:Name="JsonEditor"
                                     Grid.Row="1"
                                     FontFamily="{DynamicResource FontMono}"
                                     FontSize="15"
                                     IsReadOnly="True"
                                     Margin="0,8,0,0"
                                     ShowLineNumbers="True"
                                     WordWrap="False" />

            <Button Grid.Row="2"
                    Click="OnCloseClicked"
                    Content="{loc:Localization Close}"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,24" />

        </Grid>
    </Border>
</Window>
