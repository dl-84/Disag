{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "CurrentLanguageCode": {
      "enum": ["de", "en"]
    },
    "Database": {
      "type": "object",
      "properties": {
        "ConnectionString": {
          "type": "string"
        },
        "Provider": {
          "enum": ["PostgreSql", "Sqlite"]
        }
      },
      "required": ["ConnectionString", "Provider"],
      "additionalProperties": false
    }
  },
  "required": ["CurrentLanguageCode", "Database"],
  "additionalProperties": false
}
